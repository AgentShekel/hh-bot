# Copy this file to .env and fill in your values.
# .env is gitignored — your secrets stay local.

# === Telegram ===
# Get bot token from @BotFather, your user_id from @userinfobot.
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_ADMIN_ID=your_telegram_user_id

# === hh.ru ===
# Your phone number for hh.ru login (interactive on first run).
HH_LOGIN=+79001234567

# Optional proxy for hh.ru (Playwright browser). Required if running outside
# Russia — hh.ru blocks foreign IPs.
# Formats:
#   http://user:pass@host:port
#   http://host:port
# Note: Chromium does NOT support SOCKS5 with authentication — use HTTP tunnel.
HH_PROXY=

# === LLM providers ===
# Primary provider — DeepSeek V4 (paid, ~$1-3/month at typical usage,
# detailed Russian writing, supports thinking mode).
# Sign up at https://platform.deepseek.com
DEEPSEEK_API_KEY=

# Fallback provider — Groq with Llama 3.3 70B (free tier, ~30 req/min,
# kicks in if DeepSeek fails or hits a 5xx).
# Sign up at https://console.groq.com
GROQ_API_KEY=

# Optional alternative — GLM (Zhipu AI). Not used by default.
GLM_API_KEY=
GLM_PROXY=

# === Candidate personalisation ===
# First name used in the cover letter signature ("С уважением, <NAME>").
# The rest of the candidate context — resume summary, products, metrics,
# anti-fabrication list, opening samples — lives in prompts/candidate.txt
# (gitignored, your real data). See prompts/candidate.example.txt for the
# template.
CANDIDATE_NAME=Your First Name

# === Resume ===
# Plain text file used as full candidate context. Place a resume.txt with
# your CV content in the project root. (resume*.txt is gitignored.)
RESUME_FILE=resume.txt

# === Telegram channel monitor (optional) ===
# Reads public job channels via their web mirror (https://t.me/s/<channel>) —
# NO API keys, NO my.telegram.org, NO login. Just list channels in
# data/tg_channels.yaml. All settings below are optional (sensible defaults).
TG_MONITOR_ENABLED=true
# TG_PULL_INTERVAL=1800       # seconds between pulls (default 1800 = 30 min)
# TG_LOOKBACK_HOURS=6         # how far back each pull looks
# TG_LIMIT_PER_CHANNEL=30     # max posts examined per channel per pull
# TG_HTTP_PROXY=              # proxy for t.me if it's blocked on your network
